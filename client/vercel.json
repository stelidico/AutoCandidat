{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://autocandidat-api.fly.dev/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://autocandidat-api.fly.dev/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
