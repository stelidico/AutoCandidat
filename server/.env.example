# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# URL du frontend (CORS + postMessage OAuth)
FRONTEND_URL=http://localhost:5173

# URL publique du backend (redirect URI OAuth)
BASE_URL=http://localhost:4000

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=remplacer_par_une_chaine_aleatoire_32_caracteres_minimum

# ── Base de données ───────────────────────────────────────────────────────────
# Sur Railway : configurer un Volume monté sur /app/data et mettre DB_PATH=/app/data/autocandidat.db
DB_PATH=./data/autocandidat.db

# ── IA (Anthropic Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-votre_cle_ici

# ── Chiffrement des identifiants stockés en base (SMTP, OAuth) ────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si absent, retombe sur JWT_SECRET puis sur une clé de repli publique (à éviter en prod)
ENCRYPTION_KEY=

# ── SMTP (optionnel, pour comptes non-Gmail) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Créer des identifiants OAuth2 dans Google Cloud Console
# URI de redirection autorisée : BASE_URL/auth/google/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT=http://localhost:4000/auth/google/callback

# ── Envoi transactionnel (fallback si aucun compte email connecté) ────────────
RESEND_API_KEY=
RESEND_FROM=contact@autocandidat.fr
CONTACT_EMAIL=contact@autocandidat.fr

# ── Paiement (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Agrégateurs d'offres d'emploi ──────────────────────────────────────────────
# France Travail : https://francetravail.io
FT_CLIENT_ID=
FT_CLIENT_SECRET=
# Adzuna : https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Jooble : https://jooble.org/api/about
JOOBLE_API_KEY=
# JSearch (Google for Jobs — inclut des offres LinkedIn/Indeed/Glassdoor) : https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Gratuit jusqu'à 200 requêtes/mois, payant au-delà
RAPIDAPI_KEY=
